# Cache control headers for HTML files - prevent stale cache issues
/*.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Cache control for root index
/
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Allow long-term caching for versioned assets (JS/CSS with hashes)
/assets/*
  Cache-Control: public, max-age=31536000, immutable